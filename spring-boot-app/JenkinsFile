pipeline {
  agent {
    docker {
      image 'puganya/maven-puganya-docker-agent:java17'
      args '--user root -v /var/run/docker.sock:/var/run/docker.sock'
    }
  }
  stages {
    stage('Checkout') {
      steps {
        git branch: 'main', url: 'https://github.com/puganya-tech/My_Jenkins_Projects.git'
      }
    }
    stage('Build and Test') {
      steps {
        sh 'cd spring-boot-app && mvn clean package'
      }
    }
    stage('Static Code Analysis') {
      environment {
        SONAR_URL = "http://65.1.95.87:9000"
      }
      steps {
        withCredentials([string(credentialsId: 'Sonar', variable: 'SONAR_AUTH_TOKEN')]) {
          sh 'cd spring-boot-app && mvn sonar:sonar -Dsonar.login=$SONAR_AUTH_TOKEN -Dsonar.host.url=${SONAR_URL}'
        }
      }
    }
    stage('Build and Push Docker Image') {
      environment {
        DOCKER_IMAGE = "puganya/ultimate-cicd:${BUILD_NUMBER}"
      }
      steps {
        script {
          // Build Docker image
          sh 'cd spring-boot-app && docker build -t ${DOCKER_IMAGE} .'}
        script{
          sh 'docker login -u puganya -p Gopalakrishnan32*'
        }
        script {
          // Push to Docker Hub
          sh 'docker push ${DOCKER_IMAGE}'
        }
      }
    }
  }
}
